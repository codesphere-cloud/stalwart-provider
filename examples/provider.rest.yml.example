# REST Backend Provider Definition Example
# Copy this file to config/provider.yml and customize it for your service.
#
# This example shows a custom PostgreSQL provider backed by an external REST API.
# For landscape-based providers, see provider.yml.example instead.
#
# Full schema reference: .github/instructions/PROVIDER.instructions.md

name: custom-postgres
version: v1
author: Your Team
displayName: Custom PostgreSQL
iconUrl: https://example.com/postgres-icon.png
category: databases
description: |
  Custom PostgreSQL database provider backed by an external REST API.
  Supports automated provisioning, scaling, and lifecycle management
  through a custom backend service.

backend:
  rest:
    url: https://my-backend.example.com/postgres
    authTokenEnv: BACKEND_AUTH_TOKEN

configSchema:
  type: object
  properties:
    DATABASE_NAME:
      type: string
      description: Name of the database to create
    VERSION:
      type: string
      description: PostgreSQL version
      enum: ['16.10', '15.14', '14.19']
      x-update-constraint: immutable

secretsSchema:
  type: object
  properties:
    SUPERUSER_PASSWORD:
      type: string
      format: password
    USER_PASSWORD:
      type: string
      format: password

detailsSchema:
  type: object
  properties:
    hostname:
      type: string
    port:
      type: integer
    dsn:
      type: string
    ready:
      type: boolean

planSchema:
  type: object
  properties:
    storage:
      type: integer
      description: Storage size in MB
      x-update-constraint: increase-only
    cpu:
      type: integer
      description: CPU allocation in tenths
      x-update-constraint: increase-only
    memory:
      type: integer
      description: Memory allocation in MB
      x-update-constraint: increase-only
